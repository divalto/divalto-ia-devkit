;-- =====================================================================
;-- DIVA : declarations
;-- =====================================================================
[diva]
;-- ADAPTER : remplacer par le $Id du fichier reel
SetModuleInfo('$Id: template_zoom_sql.dhsf $')

;-- OBLIGATOIRE : record ddsys
Public Record "ddsys.dhsd" rowinfo zoomselection
;-- ADAPTER : RecordSql de l entite (noms en CamelCase)
Public RecordSql "monrecordsql.dhoq" MaVue MaVue
Public RecordSql "monrecordsql.dhoq" MaVue MaVue_Sel
[/diva]
[diva_base]
[/diva]
