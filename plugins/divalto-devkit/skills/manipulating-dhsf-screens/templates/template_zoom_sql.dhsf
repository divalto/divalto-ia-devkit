;>xwin4obj                              7.0       20260412000000
[masque]
;-- ADAPTER : libelle, utilisateur, date_modification
 libelle="Zoom sur MonEntite"
 utilisateur="ROOT"
 date_modification="12/04/2026"
 feuille_style="fstylewpf.dhfi"
 id_traitements=44
 type_masque=2
;-- ADAPTER : dernier_id >= plus grand id utilise
 dernier_id=30
 dernier_id_page=12
[defaut]
 [aide_page]
  aide=0
;-- ADAPTER : fichier aide du domaine (gtfaide, gafaide, ccfaide...)
  fichier="gtfaide"
 [touches]
  f7=135
  shift_f6=10000
[enregistrements]
;-- OBLIGATOIRE : ddsys.dhsd pour le zoom
 "ddsys.dhsd",,rowinfo,zoomselection,120,0
;-- ADAPTER : remplacer par le RecordSql de l entite
 "monrecordsql.dhoq",,mavue,mavue,1024,1
 "monrecordsql.dhoq",,mavue,mavue_sel,1024,1
;-- =====================================================================
;-- ONGLETS : FICHE (detail) + LISTE (tableau recherche)
;-- =====================================================================
[onglet]
 [presentation]
  position=0,0
  taille=225,280
  attache_lgx=oui
  attache_lgy=oui
  id=1
 [param_onglet]
  nom="FICHE"
  multi_lignes=non
  arret=2
  wnom_police="ONGLET"
  wnom_padding="ONGLET"
[onglet]
 [presentation]
  position=0,0
  taille=36,320
  id=2
 [param_onglet]
  nom="LISTE"
  multi_lignes=non
  arret=1
  wnom_police="ONGLET"
  wnom_padding="ONGLET"
;-- =====================================================================
;-- PAGE 1 : conteneur principal
;-- =====================================================================
[page]
 numero=1
 fond="STD"
 nature=double
 nb_lig=25
 nb_col=120
 offset_lig=1
 offset_col=1
 attache_lgx=oui
 attache_lgy=oui
 ident_unique=1
;-- =====================================================================
;-- PAGE 2 : popup saisie cle (creation)
;-- =====================================================================
[page]
 numero=2
 libelle="Saisie cle/creation"
 fond="ZOOM"
 nature=double
 type=fenetre
;-- ADAPTER : titre de la fenetre de creation
 titre="Entite a creer"
 nb_lig=3
 nb_col=50
 offset_lig=8
 offset_col=20
 ident_unique=2
 [obj_texte]
  [presentation]
   position=8,5
   taille=9,50
   id=3
   wstyle="STD"
  [texte]
;-- ADAPTER : libelle du champ cle
   texte="Code"
 [champ]
  [presentation]
   position=8,56
   taille=9,32
   id=4
   wstyle="ZOOM_SAISI"
  [description]
;-- ADAPTER : champ cle de l entite
   donnee=mavue,codecle,mavue
  [param_saisie]
   obligatoire=oui
  [touches]
   f1=1
  [traitements]
   microbol_click=8002
;-- =====================================================================
;-- PAGE 3 : tableau zoom + filtres (onglet LISTE)
;-- =====================================================================
[page]
 numero=3
 fond="STD"
 efface=partiel
 nb_lig=25
 nb_col=50
 offset_lig=1
 offset_col=1
 attache_lgx=oui
 attache_lgy=oui
 ident_unique=12
 [groupbox]
  [presentation]
   position=0,0
   taille=48,199
   attache_lgx=oui
   id=5
   wstyle="GROUPE"
  [param_groupbox]
   texte="Selection"
   couleur_fond="ZOOM"
 [tableau]
  [presentation]
   position=50,0
   taille=175,200
   attache_lgx=oui
   attache_lgy=oui
   id=6
   wstyle="TABLEAU_AFF"
  [param_tableau]
   nom="zoom"
   point_arret=3
   fl_trait_lig=non
   col_depl=3
   hauteur_lig=11
   hauteur_entete=10
   largeur_controle=8
   var_controle=oui
   separation=66
  [description]
   donnee=rowinfo,rowinfo,zoomselection
   minmaj=majuscules
   saisie=non
;-- ADAPTER : colonnes du tableau ci-dessous
;-- Colonne 1 : code (lecture seule)
  [champ_tableau]
   [presentation]
    position=12,168
    taille=8,18
    id=7
    wstyle="TABLEAU_AFF"
   [description]
    donnee=mavue,codecle,mavue
    saisie=non
   [traitements]
    microbol_click=8002
   [info_bulle]
   texte="Code"
   [param_colonne]
    titre="Code"
    largeur_col=34
    wstyle="ENTETE_COLONNE"
;-- Colonne 2 : libelle (saisissable)
  [champ_tableau]
   [presentation]
    position=15,40
    taille=10,160
    id=8
    wstyle="TABLEAU_SAISI"
   [description]
    donnee=mavue,lib,mavue
   [touches]
    f1=1
    f7=135
    shift_f6=10000
   [traitements]
    microbol_click=8002
   [info_bulle]
   texte="Libelle"
   [param_colonne]
    titre="Libelle"
    fl_aff=oui
    largeur_col=151
    wstyle="ENTETE_COLONNE"
;-- ADAPTER : filtres de selection (IMPORTANT : alias = mavue_sel, PAS mavue)
 [obj_texte]
  [presentation]
   position=16,5
   taille=9,43
   id=9
   wstyle="STD"
  [texte]
   texte="Code"
