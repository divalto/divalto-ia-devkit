;*
;* procedures d'initialisation et fin de zoom
;*

;*
Public Procedure Construire_Condition_Selection(nom, premier)
; Mise en place des criteres de selection et du tri
	1		nom						A
	1		premier					1,0 = FALSE		; Gestion de '*' en fin de champ
	1 		valeurCondition		S
	1  	param						S

Beginp

	{{ NomVue }}.Where.RemoveCondition(Nom)

	If {{ NomVue }}_Sel.{{ ChampCle }} <> ' '									; Code {{ ChampCle }}
		param = Banaliser_Condition({{ NomVue }}_Sel.{{ ChampCle }}, premier)		|	{{ NomVue }}.Where.Like_{{ ChampCle }}(param)		|	{{ NomVue }}.Where.Like_{{ ChampCle }}.AddAndCondition(valeurCondition)
	EndIf

{% if has_libelle %}
	If {{ NomVue }}_Sel.{{ ChampLibelle }} <> ' '									; {{ ChampLibelle }}
		param = Banaliser_Condition({{ NomVue }}_Sel.{{ ChampLibelle }}, premier)		|	{{ NomVue }}.Where.Like_{{ ChampLibelle }}(param)		|	{{ NomVue }}.Where.Like_{{ ChampLibelle }}.AddAndCondition(valeurCondition)
	EndIf
{% endif %}

	If valeurCondition <> ' '
		{{ NomVue }}.Where.AddCondition(nom, valeurCondition)
	EndIf

Endp

;*
Public Procedure ZoomDebut
Beginp
	Init_Zoom(FicheNoBloc=0)

	Load_Gtfdos(MZ.Dos)

	Zoom.TitreFixe	= Translate('{{ Description }}')

   If ZOOM.Scevaleur <> ' '
		{{ NomVue }}_Sel.Init()
{% if has_libelle %}
 		If Mid (ZOOM.Scevaleur, 1, 1) = '-'
         {{ NomVue }}_Sel.{{ ChampLibelle }}	= Mid(ZOOM.Scevaleur, 2)	|	{{ NomVue }}.Orderby.Par_{{ ChampLibelle }}()
		Else
			{{ NomVue }}_Sel.{{ ChampCle }}	= ZOOM.Scevaleur				|	{{ NomVue }}.Orderby.Par_Code()
		Endif
{% else %}
		{{ NomVue }}_Sel.{{ ChampCle }}	= ZOOM.Scevaleur				|	{{ NomVue }}.Orderby.Par_Code()
{% endif %}
		Construire_Condition_Selection(ZOOM_SQL_CONDITION_NORMALE, TRUE)
	Else
		{{ NomVue }}.Orderby.Par_Code()
   Endif

Endp

