;*
;*		Procedures creation, duplication, modification et suppression
;*

;*
Public Procedure ZoomCreation
Beginp
	If Authorize_{{ table_minuscule }}_Insert({{ NomVue }}.{{ table_minuscule }}) <> 0
		ZOOM.OK = 'I'
		preturn
	EndIf

	{{ NomVue }}.Init()								         ; Initialiser les donnees
	Initialize_{{ table_minuscule }}_New({{ NomVue }}.{{ table_minuscule }})
Endp

;*
Public Procedure ZoomDuplication
Beginp
	If Authorize_{{ table_minuscule }}_Insert({{ NomVue }}.{{ table_minuscule }}) <> 0
		ZOOM.OK = 'I'
		preturn
	EndIf

	Initialize_{{ table_minuscule }}_Duplication({{ NomVue }}.{{ table_minuscule }})
Endp

;*
Public Procedure ZoomApresCleCreation	; Apres saisie de la cle
Beginp
	If Check_{{ TABLE_MAJUSCULE }}_Key({{ NomVue }}.{{ table_minuscule }}) <> 0
		Zoom.ok = 'C'
	Endif
	{{ NomVue }}.Where.Exists({{ NomVue }}.{{ ChampCle }})
	Zoom.Res			= Get_{{ table_minuscule }}_Reservation ({{ NomVue }}.{{ table_minuscule }})
	Zoom.Titrevar	= {{ NomVue }}.{{ ChampCle }}
Endp

;*
Public Procedure ZoomCreationRes			; Apres reservation en creation
Beginp
Endp

;*
Public Procedure ZoomAvantWrite
Beginp
	if Check_{{ TABLE_MAJUSCULE }}({{ NomVue }}.{{ table_minuscule }}) <> 0
		Zoom.Ok = 'S'
		Preturn
	endif
	{{ PREFIX_ }}PreInsert_recordSql({{ NomVue }})
Endp

;*
Public Procedure ZoomApresCreation			; Compte-rendu de creation
Beginp
	If Zoom.Ok = 'O'
		{{ PREFIX_ }}PostInsert_recordSql({{ NomVue }})
	EndIf
	Zoom.Titrevar = TitreVariable
Endp

