{% if seeds.chain_of_blame.available %}
## Chaine d'appels

```mermaid
flowchart TD
{% for node in seeds.chain_of_blame.nodes %}
{% set nid = 'N' ~ loop.index0 %}
{% if node.kind == 'ui' %}
    {{ nid }}["UI : {{ node.label | truncate(55) | replace('"', '') }}"]
{% elif node.kind == 'fn' %}
    {{ nid }}["{{ node.name }}<br/>{{ node.file }}:{{ node.line }}"]
{% elif node.kind == 'fn_noline' %}
    {{ nid }}["{{ node.name }}<br/>{{ node.file }} (ligne ?)"]
{% elif node.kind == 'action' %}
{% if node.file and node.line %}
    {{ nid }}["A5_Action_Generer_Action({{ node.const }})<br/>{{ node.file }}:{{ node.line }}"]
{% else %}
    {{ nid }}["A5_Action_Generer_Action({{ node.const }})<br/>(emplacement dans le callee)"]
{% endif %}
{% elif node.kind == 'gap' %}
    {{ nid }}(["{{ node.label | replace('`', '') | replace('"', '') }}"])
    style {{ nid }} fill:#f96,stroke:#333,stroke-width:3px,color:#000
{% endif %}
{% if not loop.first %}
    N{{ loop.index0 - 1 }} --> {{ nid }}
{% endif %}
{% endfor %}
```

