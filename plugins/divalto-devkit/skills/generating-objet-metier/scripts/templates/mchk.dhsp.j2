;*
function int Find_{{ TABLE_MAJUSCULE }}_PK(&{{ NOMVUE_MAJUSCULE }},{{ ChampCle }},allcolumns,context)
;recherche instance par cle primaire
Declaration_{{ NOMVUE_MAJUSCULE }}
1    allcolumns    1,0 = false
1     context           1,0 = false    ; context true/false
1 {{ ChampCle }} >{{ DICT }}.dhsd {{ ChampCle }}
beginf
	If SeekAndLoad_{{ TABLE_MAJUSCULE }}({{ NOMVUE_MAJUSCULE }},{{ CHAMPCLE }},allcolumns) = 0
		FReturn(0)
	else
		{{ PREFIX_ }}GererErreurCheck(30002,{{ ChampCle }},context=context)
		FReturn(1)
	endif
endf
{% if has_libelle %};*
function int Find_{{ TABLE_MAJUSCULE }}_Lib(&{{ NOMVUE_MAJUSCULE }}	,{{ ChampCle }},allcolumns,context)
;recherche instance par libelle
Declaration_{{ NOMVUE_MAJUSCULE }}
1    allcolumns    1,0 = false
1     context           1,0 = false    ; context true/false
1     {{ ChampCle }}          A
1     vCondition     S = ' '
1     nCondition     S = '{{ NOMVUE_MAJUSCULE }}	'
1     nom            S
beginf
	{{ PREFIX_ }}Check_ActivateColumns(ChkData_{{ TABLE_MAJUSCULE }},{{ NOMVUE_MAJUSCULE }},allcolumns,Condition(allcolumns,Get_{{ TABLE_MAJUSCULE }}_FieldNames_All,Get_{{ TABLE_MAJUSCULE }}_FieldNames_Min))
	; il faut une clause where et un tri sur le libelle
	{{ NOMVUE_MAJUSCULE }}	.OrderBy.Par_{{ ChampLibelle }}()
	{{ NOMVUE_MAJUSCULE }}	.Where.Like_{{ ChampLibelle }}((Banaliser_Condition({{ ChampCle }}, TRUE)))
	{{ NOMVUE_MAJUSCULE }}	.Where.Like_{{ ChampLibelle }}.AddAndCondition(vcondition)
	{{ NOMVUE_MAJUSCULE }}	.Where.AddCondition(nCondition, vCondition)
	If Select_{{ NOMVUE_MAJUSCULE }}	({{ NOMVUE_MAJUSCULE }}	) = 0
		FReturn(0)
	Else
		{{ PREFIX_ }}GererErreurCheck(30002,{{ ChampCle }},context=context)
		FReturn(5)
	EndIf
Endf
{% endif %};*
Public function int Find_{{ TABLE_MAJUSCULE }}(&{{ ChampCle }},allcolumns,context)
;controle instance par cle primaire
1     {{ ChampCle }}             >{{ DICT }}.dhsd {{ ChampCle }}
1     allcolumns     1,0 = false
1     context           1,0 = false    ; context true/false
1     ret            1,0
beginf
	if ( {{ CHAMPCLE }} = ' ' )   |RS_{{ NomVue }}.init() | FReturn(0) | endif
	; preparation selection
{% if has_libelle %}	SwitchString Left({{ ChampCle }},1)
		case '-'     | ret = Find_{{ TABLE_MAJUSCULE }}_Lib(RS_{{ NOMVUE_MAJUSCULE }}	,Mid({{ ChampCle }}, 2, datasize({{ ChampCle }})-1),allcolumns,context=context)
		default      | ret = Find_{{ TABLE_MAJUSCULE }}_PK(RS_{{ NOMVUE_MAJUSCULE }}	,{{ ChampCle }},allcolumns,context=context)
	endswitch
{% else %}	ret = Find_{{ TABLE_MAJUSCULE }}_PK(RS_{{ NOMVUE_MAJUSCULE }}	,{{ ChampCle }},allcolumns,context=context)
{% endif %}
	if RET <> 0
		; la recherche a echoue
		RS_{{ NOMVUE_MAJUSCULE }}.INIT()
	else
		; la recherche a reussi
		{{ ChampCle }} = RS_{{ NOMVUE_MAJUSCULE }}.{{ ChampCle }}
		; controles supplementaires si necessaires
	endif
	FReturn(Ret)
endf
;*
Public function int Exists_{{ TABLE_MAJUSCULE }}({{ ChampCle }})
;controle d'existence simple, mais qui ne garni aucun donnee
;retour true=existe, false = n'existe pas
1     {{ ChampCle }} >{{ DICT }}.dhsd {{ ChampCle }}
1     ret            1,0
Declaration_{{ NOMVUE_MAJUSCULE }}	 {{ NOMVUE_MAJUSCULE }}_loc
beginf
	ret = SeekAndLoad_{{ TABLE_MAJUSCULE }}({{ NOMVUE_MAJUSCULE }}_loc,{{ ChampCle }},false)
	If ret = 0
		;existe deja, c'est pas ce qu'on veut
		{{ PREFIX_ }}GererErreurCheck(9500,{{ ChampCle }},ChkData_{{ TABLE_MAJUSCULE }})
		FReturn(true)
	else
		FReturn(false)
	EndIf
endf
