function int SeekAndLoad_{{ TABLE_MAJUSCULE }}(&{{ NOMVUE_MAJUSCULE }},{{ ChampCle }},allcolumns)
Declaration_{{ NOMVUE_MAJUSCULE }}
Record {{ DICT }}.dhsd {{ TABLE_MAJUSCULE }}  {{ TABLE_MAJUSCULE }}_Seek
1     {{ ChampCle }}             >{{ DICT }}.dhsd {{ ChampCle }}
1     allcolumns     1,0 = false
1     ret            1,0
beginf

	if A5Chk_CacheMode_Active(ChkData_{{ TABLE_MAJUSCULE }}, allcolumns)
	; key pour le listseek
		{{ TABLE_MAJUSCULE }}_Seek.Dos     = MZ.dos
		{{ TABLE_MAJUSCULE }}_Seek.{{ ChampCle }} = {{ ChampCle }}
		if A5Chk_CacheMode_Seek(ChkData_{{ TABLE_MAJUSCULE }}, allcolumns, {{ TABLE_MAJUSCULE }}_Seek, {{ NOMVUE_MAJUSCULE }}.{{ TABLE_MAJUSCULE }})
			freturn(0)
		endif
	endif
	{{ PREFIX_ }}Check_ActivateColumns(ChkData_{{ TABLE_MAJUSCULE }},{{ NOMVUE_MAJUSCULE }},allcolumns,Condition(allcolumns,Get_{{ TABLE_MAJUSCULE }}_FieldNames_All,Get_{{ TABLE_MAJUSCULE }}_FieldNames_Min))
	ret = Seek_{{ NOMVUE_MAJUSCULE }}({{ NOMVUE_MAJUSCULE }},{{ ChampCle }})
	if ret = 0
		A5Chk_CacheMode_Insert(ChkData_{{ TABLE_MAJUSCULE }}, allcolumns, {{ NOMVUE_MAJUSCULE }}.{{ TABLE_MAJUSCULE }})
	else
		{{ NOMVUE_MAJUSCULE }}.Init()
	endif
	FReturn(ret)
endf
