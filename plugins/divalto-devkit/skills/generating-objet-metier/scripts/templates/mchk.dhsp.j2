;*
Public function int Check_{{ TABLE_MAJUSCULE }}_Field_{{ fk.champ }}(&{{ TABLE_MAJUSCULE }})
;controle du champ {{ fk.champ }} (FK vers {{ fk.target }})
Record {{ DICT }}.dhsd {{ TABLE_MAJUSCULE }}	{{ TABLE_MAJUSCULE }}
1	ret		3,0
beginf
	if (ret := {{ PREFIX_ }}CheckField(RS_{{ NomVue }}, {{ TABLE_MAJUSCULE }}, "{{ fk.champ }}")) <> 0
		freturn(ret)
	endif
	freturn({{ fk.find_fn }}({{ TABLE_MAJUSCULE }}.{{ fk.champ }}, context=true))
endf

;*
Public function int Check_{{ TABLE_MAJUSCULE }}_Field_{{ fk.champ }}_Lib(&{{ TABLE_MAJUSCULE }}, &Lib)
;controle du champ {{ fk.champ }} + libelle retourne ({{ fk.get_lib_fn }})
Record {{ DICT }}.dhsd {{ TABLE_MAJUSCULE }}	{{ TABLE_MAJUSCULE }}
1	Lib		A
1	ret		3,0
beginf
	ret = Check_{{ TABLE_MAJUSCULE }}_Field_{{ fk.champ }}({{ TABLE_MAJUSCULE }})
	if ret = 0
		Lib = {{ fk.get_lib_fn }}
	else
		Lib = ' '
	endif
	freturn(ret)
endf
