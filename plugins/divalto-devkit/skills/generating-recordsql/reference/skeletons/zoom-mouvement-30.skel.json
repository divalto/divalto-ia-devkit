      "columns_selected": ["ART.ArtLib"]
    },
    {
      "table_sql": "DEPO",
      "alias": "DEPO",
      "join_type": "left_join",
      "join_condition": "DEPO.Dos = MZ.Dos AND DEPO.DepoCod = {MAIN}.DepoCod",
      "columns_selected": ["DEPO.DepoLib"]
    },
    {
      "table_sql": "LOTDET",
      "alias": "LOTDET",
      "join_type": "left_join",
      "join_condition": "LOTDET.Dos = MZ.Dos AND LOTDET.NumLot = {MAIN}.NumLot AND LOTDET.ArtCod = {MAIN}.ArtCod",
      "columns_selected": ["LOTDET.DateFab"]
    },
    {
      "table_sql": "BF",
      "alias": "BF",
      "join_type": "left_join",
      "join_condition": "BF.Dos = MZ.Dos AND BF.BfCod = {MAIN}.BfCod",
      "columns_selected": ["BF.BfLib"]
    },
    {
      "table_sql": "T006",
      "alias": "T006",
      "join_type": "left_join",
      "join_condition": "T006.Dos = MZ.Dos AND T006.Code = {MAIN}.TypeMvt",
      "columns_selected": ["T006.Lib"]
    },
    {
      "table_sql": "T007",
      "alias": "T007",
      "join_type": "left_join",
      "join_condition": "T007.Dos = MZ.Dos AND T007.Code = {MAIN}.SensMvt",
      "columns_selected": ["T007.Lib"]
    },
    {
      "table_sql": "U",
      "alias": "U",
      "join_type": "left_join",
      "join_condition": "U.Dos = MZ.Dos AND U.UnCod = {MAIN}.UnCod",
      "columns_selected": ["U.UnLib"]
    }
  ],
  "additional_cases": [
    {"name": "Equal_ArtCod", "field": "ArtCod", "type": "equal", "param": "char"},
    {"name": "Equal_DepoCod", "field": "DepoCod", "type": "equal", "param": "char"},
    {"name": "Equal_NumLot", "field": "NumLot", "type": "equal", "param": "char"},
